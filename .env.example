# Required for LLM reasoning and policy embeddings
GOOGLE_API_KEY=

# Models (defaults shown)
LLM_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001

# Policy thresholds — enforced in code, not prompts
AUTO_APPROVE_LIMIT=500
HARD_CEILING=10000
RECEIPT_REQUIRED_ABOVE=25
CONFIDENCE_FLOOR=0.6
DUPLICATE_WINDOW_HOURS=24

# Comma-separated vendor names (case-insensitive)
VENDOR_BLACKLIST=shadow consulting ltd,quickcash services,luxe gifts co

# Retrieval
TOP_K=4

# Storage (optional — defaults to data/ under project root)
# EXPENSE_AGENT_DB=data/expense_agent.db
# EXPENSE_AGENT_CHECKPOINT_DB=data/checkpoints.db
# EXPENSE_AGENT_POLICY=policy/expense_policy.md

# Eval: seconds between cases (free-tier rate limits)
# EVAL_PACE_S=0
